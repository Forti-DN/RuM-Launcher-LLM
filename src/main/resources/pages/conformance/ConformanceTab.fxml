                            <RowConstraints minHeight="10.0" prefHeight="20.0" vgrow="SOMETIMES" />
                          </rowConstraints>
                           <children>
                              <RadioButton fx:id="symbaButton" mnemonicParsing="false" selected="true" text="SymBA*-2">
                                 <toggleGroup>
                                    <ToggleGroup fx:id="plannerAlgorithm" />
                                 </toggleGroup>
                              </RadioButton>
                              <RadioButton fx:id="fastDownwardButton" mnemonicParsing="false" text="Fast-Downward" toggleGroup="$plannerAlgorithm" GridPane.rowIndex="1" />
                           </children>
                        </GridPane>
                     </content>
                  </TitledPane>
                  <HBox styleClass="buttons-group--primary">
