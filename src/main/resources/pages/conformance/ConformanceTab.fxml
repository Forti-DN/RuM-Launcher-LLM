                           </children>
                        </GridPane>
                        <Label fx:id="methodWarningLabel" styleClass="file-path-label" />
                     </children>
                  </VBox>
                  <TitledPane fx:id="flowSettingsPane" styleClass="parameters-pane" text="Control Flow Cost Model">
                    <content>
                        <VBox styleClass="parameters-pane__content-box">
                           <children>
                              <GridPane>
                                 <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="55.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="45.0" />
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                 </rowConstraints>
                                 <children>
                                    <Label text="Default Insertion Cost:" />
                                    <TextField fx:id="defaultInsertionCost" GridPane.columnIndex="1" />
                                    <Label text="Default Deletion Cost:" GridPane.rowIndex="1" />
                                    <TextField fx:id="defaultDeletionCost" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                 </children>
                              </GridPane>
                              <Button fx:id="toggleFlowSettingsButton" mnemonicParsing="false" onAction="#toggleFlowSettings" styleClass="selection-button" text="Add specific costs">
                                 <graphic>
                                    <FontIcon iconLiteral="fa-angle-double-right" styleClass="selection-button__icon" />
                                 </graphic>
                              </Button>
                           </children>
                        </VBox>
                    </content>
                  </TitledPane>
                  <TitledPane fx:id="dataSettingsPane" styleClass="parameters-pane" text=" Data Cost Model">
                    <content>
                        <VBox styleClass="parameters-pane__content-box">
                           <children>
                              <GridPane>
                                 <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="55.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="45.0" />
