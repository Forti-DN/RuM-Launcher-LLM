<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="rootRegion" styleClass="standard-bg-color" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.discovery.DiscoveryPageController">
   <children>
      <HBox styleClass="header__layout">
         <children>
            <Label styleClass="header__title" text="Discovery" />
            <Button mnemonicParsing="false" onAction="#openLog" styleClass="header__button" text="Open Log">
               <graphic>
                  <FontIcon iconLiteral="typ-document" styleClass="header__icon" wrappingWidth="30.0" />
               </graphic>
            </Button>
         </children>
      </HBox>
      <Label fx:id="introLabel" styleClass="page-intro-label" text="Click &quot;Open Log&quot; to get started with process discovery" VBox.vgrow="ALWAYS" />
      <TabPane fx:id="discoveryTabPane" VBox.vgrow="ALWAYS" />
   </children>
</VBox>
