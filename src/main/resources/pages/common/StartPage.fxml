<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<ScrollPane fx:id="rootRegion" fitToHeight="true" fitToWidth="true" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.common.StartPageController">
   <content>
      <HBox styleClass="standard-bg-color">
         <children>
            <Region HBox.hgrow="ALWAYS" />
            <FlowPane prefWrapLength="1000.0" styleClass="start-page__icon-panel" HBox.hgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#openDiscovery" styleClass="start-page__button" text="Discovery">
                     <graphic>
                        <ImageView fitHeight="225.0" fitWidth="225.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../images/lightbulb.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <FlowPane.margin>
                        <Insets />
                     </FlowPane.margin>
                  </Button>
                  <Button layoutX="96.0" layoutY="35.0" mnemonicParsing="false" onAction="#openConformance" styleClass="start-page__button" text="Conformance Checking">
                     <graphic>
                        <ImageView fitHeight="225.0" fitWidth="225.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../images/test.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button layoutX="96.0" layoutY="35.0" mnemonicParsing="false" onAction="#openGeneration" styleClass="start-page__button" text="Log Generation">
                     <graphic>
                        <ImageView fitHeight="225.0" fitWidth="225.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../images/book.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button layoutX="96.0" layoutY="35.0" mnemonicParsing="false" onAction="#openEditor" styleClass="start-page__button" text="MP-Declare Editor">
                     <graphic>
                        <ImageView fitHeight="225.0" fitWidth="225.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../images/notepad.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button layoutX="96.0" layoutY="35.0" mnemonicParsing="false" onAction="#openMonitoring" styleClass="start-page__button" text="Monitoring">
                     <graphic>
                        <ImageView fitHeight="225.0" fitWidth="225.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../images/analytics.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button layoutX="96.0" layoutY="35.0" mnemonicParsing="false" onAction="#openFiltering" styleClass="start-page__button" text="Filtering">
                     <graphic>
                        <ImageView fitHeight="225.0" fitWidth="225.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../images/filtering.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </FlowPane>
            <Region HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
   </content>
</ScrollPane>
