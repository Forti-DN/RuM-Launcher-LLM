<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox fx:id="rootRegion" alignment="CENTER_LEFT" prefHeight="32.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label fx:id="displayTextLabel" maxWidth="1.7976931348623157E308" text="ER Registration" HBox.hgrow="ALWAYS" />
      <Button fx:id="editButton" alignment="CENTER" mnemonicParsing="false" styleClass="action-cell__button">
         <graphic>
            <FontIcon fx:id="editFontIcon" iconLiteral="fa-pencil" styleClass="action-cell__edit-icon" />
         </graphic>
      </Button>
      <Separator fx:id="buttonsSeparator" orientation="VERTICAL" styleClass="separator--secondary">
         <padding>
            <Insets bottom="5.0" left="1.0" right="1.0" top="5.0" />
         </padding>
      </Separator>
      <Button fx:id="deleteButton" alignment="CENTER" layoutX="91.0" layoutY="14.0" minWidth="26.0" mnemonicParsing="false" styleClass="action-cell__button">
         <graphic>
            <FontIcon fx:id="deleteFontIcon" iconLiteral="fa-trash" styleClass="action-cell__delete-icon" />
         </graphic>
      </Button>
   </children>
</HBox>
