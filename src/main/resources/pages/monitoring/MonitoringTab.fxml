<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.web.WebView?>
<?import org.controlsfx.control.ToggleSwitch?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane fx:id="rootRegion" styleClass="standard-bg-color" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.monitoring.MonitoringTabController">
   <children>
      <HBox fx:id="mainContents">
         <children>
            <VBox fx:id="parametersSection">
               <children>
                  <VBox styleClass="single-parameter">
                     <children>
                        <GridPane>
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="55.0" prefWidth="100.0" />
                              <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" percentWidth="45.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                           </rowConstraints>
                           <children>
                              <Label styleClass="section-box__title" text="Log file" />
                              <Button fx:id="logFileButton" mnemonicParsing="false" onAction="#selectLogFile" styleClass="standard-button" text="Select" GridPane.columnIndex="1" />
                           </children>
                        </GridPane>
                        <Label fx:id="logPathLabel" styleClass="file-path-label" />
                     </children>
                  </VBox>
                  <VBox styleClass="single-parameter">
                     <children>
                        <GridPane>
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" percentWidth="55.0" />
                              <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" percentWidth="45.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                           </rowConstraints>
                           <children>
                              <Label styleClass="section-box__title" text="Monitoring method" />
                              <ChoiceBox fx:id="methodChoice" maxWidth="1.7976931348623157E308" styleClass="standard-choice-box" GridPane.columnIndex="1" />
                           </children>
                        </GridPane>
                        <Label fx:id="methodWarningLabel" styleClass="file-path-label" />
                     </children>
                  </VBox>
                  <VBox layoutX="30.0" layoutY="100.0" styleClass="single-parameter">
                     <children>
                        <GridPane>
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" percentWidth="55.0" />
                              <ColumnConstraints hgrow="SOMETIMES" percentWidth="45.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                           </rowConstraints>
                           <children>
                              <Label styleClass="section-box__title" text="Conflict Check" />
                              <ToggleSwitch fx:id="conflictCheckToggle" selected="false" GridPane.columnIndex="1" />
                           </children>
                        </GridPane>
                     </children>
                  </VBox>
                  <TitledPane fx:id="metaconstraintsPane" styleClass="parameters-pane" text="Metaconstraints">
                     <content>
                        <VBox styleClass="parameters-pane__content-box--scroll">
                           <children>
                              <TreeView fx:id="metaconstraintsTreeView" minHeight="44.0" prefHeight="44.0" />
                              <Button fx:id="addMetaconstraintButton" mnemonicParsing="false" onAction="#showMetaconstraintLayer" styleClass="selection-button" text="Add metaconstraints">
                                 <graphic>
                                    <FontIcon iconLiteral="fa-angle-double-right" styleClass="selection-button__icon" />
                                 </graphic>
                              </Button>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
                  <TitledPane animated="false" expanded="false" styleClass="parameters-pane" text="Model Constraints">
                     <content>
                        <ListView fx:id="constraintListView" focusTraversable="false" />
                     </content>
                  </TitledPane>
                  <HBox styleClass="buttons-group--primary">
                     <children>
                        <Button fx:id="monitoringButton" mnemonicParsing="false" onAction="#startMonitoring" styleClass="standard-button" text="Monitor" />
                     </children>
                  </HBox>
               </children>
               <styleClass>
                  <String fx:value="section-box" />
                  <String fx:value="section-box--main-parameters" />
               </styleClass>
            </VBox>
            <Separator orientation="VERTICAL" styleClass="separator--primary" />
            <StackPane fx:id="resultsContainer" alignment="CENTER_LEFT" onMouseClicked="#hideMetaconstraintSettings" HBox.hgrow="ALWAYS">
               <children>
                  <SplitPane fx:id="resultsSplitPane" dividerPositions="0.5">
                     <items>
                        <VBox styleClass="section-box">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="section-box__title" text="Visualization" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <HBox alignment="CENTER_LEFT" fillHeight="false" spacing="5.0">
                                             <children>
                                                <Label text="Zoom" />
                                                <Slider fx:id="zoomSlider" blockIncrement="0.1" max="4.0" value="1.0" />
                                                <HBox alignment="CENTER_LEFT" prefWidth="45.0" styleClass="percentage-box">
                                                   <children>
                                                      <TextField fx:id="zoomValueField" alignment="CENTER_RIGHT" maxWidth="34.0" style="-fx-background-color: transparent;" text="100.0">
                                                         <padding>
                                                            <Insets bottom="2.0" left="2.0" top="2.0" />
                                                         </padding>
                                                      </TextField>
                                                      <Label text="\%" />
                                                   </children>
                                                </HBox>
                                             </children>
                                             <opaqueInsets>
                                                <Insets />
                                             </opaqueInsets>
                                          </HBox>
                                       </children>
                                    </HBox>
                                    <HBox>
                                       <children>
                                          <GridPane>
                                             <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="55.0" minWidth="50.0" prefWidth="55.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="140.0" minWidth="115.0" prefWidth="140.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="140.0" minWidth="115.0" prefWidth="140.0" />
                                             </columnConstraints>
                                             <rowConstraints>
                                                <RowConstraints minHeight="20.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="20.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="20.0" vgrow="SOMETIMES" />
                                             </rowConstraints>
                                             <children>
                                                <Label text="Legend:">
                                                   <font>
                                                      <Font name="System Bold" size="12.0" />
                                                   </font>
                                                </Label>
                                                <Label text="Temporarily Satisfied" GridPane.columnIndex="1">
                                                   <graphic>
                                                      <HBox>
                                                         <styleClass>
                                                            <String fx:value="legend" />
                                                            <String fx:value="legend--temp-sat" />
                                                         </styleClass>
                                                      </HBox>
                                                   </graphic>
                                                </Label>
                                                <Label text="Permanently Satisfied" GridPane.columnIndex="2">
                                                   <graphic>
                                                      <HBox>
                                                         <styleClass>
                                                            <String fx:value="legend" />
                                                            <String fx:value="legend--perm-sat" />
                                                         </styleClass>
                                                      </HBox>
                                                   </graphic>
                                                </Label>
                                                <Label text="Temporarily Violated" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                   <graphic>
                                                      <HBox>
                                                         <styleClass>
                                                            <String fx:value="legend" />
                                                            <String fx:value="legend--temp-viol" />
                                                         </styleClass>
                                                      </HBox>
                                                   </graphic>
                                                </Label>
                                                <Label text="Permanently Violated" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                                   <graphic>
                                                      <HBox>
                                                         <styleClass>
                                                            <String fx:value="legend" />
                                                            <String fx:value="legend--perm-viol" />
                                                         </styleClass>
                                                      </HBox>
                                                   </graphic>
                                                </Label>
                                                <Label text="Conflict" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                                   <graphic>
                                                      <HBox>
                                                         <styleClass>
                                                            <String fx:value="legend" />
                                                            <String fx:value="legend--conflict" />
                                                         </styleClass>
                                                      </HBox>
                                                   </graphic>
                                                </Label>
                                             </children>
                                          </GridPane>
                                          <Region HBox.hgrow="ALWAYS" />
                                          <VBox spacing="5.0">
                                             <children>
                                                <Button fx:id="takeScreenshotButton" maxHeight="30.0" mnemonicParsing="false" onAction="#takeScreenshot" styleClass="standard-button" text="Screenshot">
                                                   <graphic>
                                                      <FontIcon iconLiteral="fa-photo" styleClass="standard-button__icon" />
                                                   </graphic>
                                                </Button>
                                                <ChoiceBox fx:id="monitorViewChoiceBox" maxHeight="30.0" maxWidth="1.7976931348623157E308" styleClass="standard-choice-box" />
                                             </children>
                                          </VBox>
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              <Separator styleClass="separator--secondary">
                                 <VBox.margin>
                                    <Insets />
                                 </VBox.margin>
                              </Separator>
                              <HBox fx:id="visualizationTogglesHBox" alignment="CENTER_LEFT" spacing="30.0">
                                 <children>
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label text="Constraint labels" />
                                          <ToggleSwitch fx:id="constraintLabelsToggle" selected="true" />
                                       </children>
                                    </HBox>
                                    <HBox fx:id="conditionLabelsToggleHBox" spacing="5.0">
                                       <children>
                                          <Label text="Condition labels" />
                                          <ToggleSwitch fx:id="conditionLabelsToggle" selected="true" />
                                       </children>
                                    </HBox>
                                    <HBox layoutX="207.0" layoutY="10.0" spacing="5.0">
                                       <children>
                                          <Label text="Alternative Layout" />
                                          <ToggleSwitch fx:id="horizontalToggle" />
                                       </children>
                                    </HBox>
                                 </children>
                              </HBox>
                              <WebView fx:id="visualizationWebView" focusTraversable="false" maxHeight="-1.0" maxWidth="-1.0" minHeight="-1.0" minWidth="-1.0" prefHeight="-1.0" prefWidth="-1.0" VBox.vgrow="ALWAYS">
                                 <VBox.margin>
                                    <Insets />
                                 </VBox.margin>
                              </WebView>
                              <fx:include fx:id="fluentsVisualization" source="FluentsVisualization.fxml" VBox.vgrow="ALWAYS" />
                              <HBox fx:id="timelineControls" alignment="CENTER_LEFT" spacing="5.0" VBox.vgrow="NEVER">
                                 <children>
                                    <Button fx:id="stepBackwardButton" maxHeight="25.0" minHeight="25.0" mnemonicParsing="false" onAction="#stepBackward" styleClass="small-button">
                                       <graphic>
                                          <FontIcon iconLiteral="fa-step-backward" styleClass="small-button__icon" />
                                       </graphic>
                                    </Button>
                                    <Button fx:id="playPauseButton" maxHeight="25.0" minHeight="25.0" minWidth="30.0" mnemonicParsing="false" onAction="#playPause" styleClass="small-button">
                                       <graphic>
                                          <FontIcon fx:id="playFonticon" iconLiteral="fa-play" styleClass="small-button__icon" />
                                       </graphic>
                                    </Button>
                                    <Button fx:id="stepForwardButton" maxHeight="25.0" minHeight="25.0" mnemonicParsing="false" onAction="#stepForward" styleClass="small-button">
                                       <graphic>
                                          <FontIcon iconLiteral="fa-step-forward" styleClass="small-button__icon" />
                                       </graphic>
                                    </Button>
                                    <HBox alignment="CENTER" prefWidth="50.0">
                                       <children>
                                          <Label fx:id="currentEventNumber" text="0" />
                                          <Label text="/" />
                                          <Label fx:id="totalEventsNumber" text="10" />
                                       </children>
                                    </HBox>
                                    <Slider fx:id="eventSlider" blockIncrement="0.0" majorTickUnit="1.0" max="10.0" minorTickCount="0" showTickMarks="true" HBox.hgrow="ALWAYS">
                                       <HBox.margin>
                                          <Insets top="8.0" />
                                       </HBox.margin>
                                    </Slider>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <VBox minWidth="150.0" styleClass="section-box">
                           <children>
                              <FlowPane hgap="40.0" vgap="10.0">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                                       <children>
                                          <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="section-box__title" text="Trace: " />
                                          <ComboBox fx:id="traceChoice" prefWidth="140.0" styleClass="standard-combo-box" visibleRowCount="25" />
                                       </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label minWidth="95.0" text="Show Payloads:" />
                                          <ToggleSwitch fx:id="showPayloadsToggle" />
                                       </children>
                                    </HBox>
                                 </children>
                              </FlowPane>
                              <ListView fx:id="eventsListView" focusTraversable="false" styleClass="monitor-events-list" VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                     </items>
                  </SplitPane>
               </children>
            </StackPane>
         </children>
      </HBox>
   </children>
</StackPane>
