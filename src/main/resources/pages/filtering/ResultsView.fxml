<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox fx:id="mainContents" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.filtering.ResultsViewController">
    <padding>
        <Insets left="10.0" right="10.0" />
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="20.0" VBox.vgrow="NEVER">
        <VBox.margin>
            <Insets bottom="10.0" top="25.0" />
        </VBox.margin>
        <ChoiceBox fx:id="perspectiveChoice" prefHeight="31.0" prefWidth="164.0" styleClass="standard-choice-box" HBox.hgrow="NEVER">
            <HBox.margin>
                <Insets left="20.0" />
            </HBox.margin>
        </ChoiceBox>
        <HBox alignment="CENTER_RIGHT" fillHeight="false" nodeOrientation="LEFT_TO_RIGHT" spacing="5.0" HBox.hgrow="ALWAYS">
            <Button maxHeight="31.0" mnemonicParsing="false" onAction="#exportFulfilledTraces" prefHeight="31.0" styleClass="standard-button" text="Export fulfilled traces" HBox.hgrow="NEVER">
                <graphic>
                    <FontIcon iconLiteral="typ-export" styleClass="standard-button__icon" />
                </graphic>
                <HBox.margin>
                    <Insets />
                </HBox.margin>
            </Button>
         <Button maxHeight="31.0" mnemonicParsing="false" onAction="#exportViolatedTraces" prefHeight="31.0" styleClass="standard-button" text="Export violated traces" HBox.hgrow="NEVER">
            <graphic>
               <FontIcon iconLiteral="typ-export" styleClass="standard-button__icon" />
            </graphic>
         </Button>
            <Button maxHeight="31.0" mnemonicParsing="false" onAction="#takeSnapshot" prefHeight="31.0" styleClass="standard-button" text="Snapshot" HBox.hgrow="NEVER">
                <graphic>
                    <FontIcon iconLiteral="fa-cube" styleClass="standard-button__icon" />
                </graphic>
                <HBox.margin>
                    <Insets right="20.0" />
                </HBox.margin>
            </Button>
         <HBox.margin>
            <Insets right="5.0" />
         </HBox.margin>
        </HBox>
    </HBox>
</VBox>
