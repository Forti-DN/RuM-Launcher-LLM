<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox fx:id="rootRegion" styleClass="standard-bg-color" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.filtering.FilteringPageController">
    <HBox styleClass="header__layout">
        <Label styleClass="header__title" text="Filtering" />
        <Button mnemonicParsing="false" onAction="#openLog" styleClass="header__button" text="Open Log">
            <graphic>
                <FontIcon iconLiteral="typ-document" styleClass="header__icon" wrappingWidth="30.0" />
            </graphic>
        </Button>
    </HBox>
    <Label fx:id="introLabel" styleClass="page-intro-label" text="Click &quot;Open Log&quot; to get started with Filtering" VBox.vgrow="ALWAYS" />
    <TabPane fx:id="filteringTabPane" VBox.vgrow="ALWAYS" />
</VBox>
