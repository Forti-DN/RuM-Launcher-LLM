<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox fx:id="rootRegion" styleClass="action-cell" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Button fx:id="firstButton" mnemonicParsing="false" styleClass="action-cell__button">
         <graphic>
            <FontIcon fx:id="editFontIcon" iconLiteral="fa-pencil" styleClass="action-cell__edit-icon" />
         </graphic>
      </Button>
      <Separator orientation="VERTICAL" styleClass="separator--secondary" />
      <Button fx:id="secondButton" mnemonicParsing="false" styleClass="action-cell__button">
         <graphic>
            <FontIcon fx:id="deleteFontIcon" iconLiteral="fa-trash" styleClass="action-cell__delete-icon" />
         </graphic>
      </Button>
   </children>
</HBox>
